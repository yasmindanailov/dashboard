# ============================================================================
# Variables de entorno — Backend (NestJS)
# ============================================================================
#
# Copia este archivo como `.env` y rellena los valores reales.
# El archivo `.env` está en .gitignore — nunca se commitea.
#
# Las variables marcadas como REQUIRED rompen el arranque si faltan.
# Las OPTIONAL tienen valor por defecto razonable.
# ============================================================================

# ── Server ──
PORT=3001                                   # OPTIONAL — puerto HTTP, default 3001
NODE_ENV=development                         # development | production | test
NEXT_PUBLIC_APP_URL=http://localhost:3002    # OPTIONAL — origen permitido en CORS

# ── Database (Prisma) ──
DATABASE_URL=postgresql://USER:PASS@localhost:5432/aelium_dashboard   # REQUIRED

# ── Redis (BullMQ + cache) ──
REDIS_URL=redis://localhost:6379             # REQUIRED

# ── Auth ──
JWT_ACCESS_SECRET=cambiar-en-produccion      # REQUIRED — mínimo 32 chars
JWT_REFRESH_SECRET=cambiar-en-produccion     # REQUIRED — distinto del access
JWT_ACCESS_TTL=15m                           # OPTIONAL
JWT_REFRESH_TTL=7d                           # OPTIONAL

# ── Email (SMTP — MailPit en dev, real en prod) ──
SMTP_HOST=localhost                          # REQUIRED
SMTP_PORT=1025                               # REQUIRED
SMTP_USER=                                   # OPTIONAL (vacío en MailPit local)
SMTP_PASS=                                   # OPTIONAL
SMTP_FROM=noreply@aelium.com                 # REQUIRED

# ── Sentry (observabilidad de errores) ──
# Sin SENTRY_DSN definido → Sentry inactivo (no envía datos, no consume).
# Activar solo en staging/production. En dev local dejar vacío.
SENTRY_DSN=                                  # OPTIONAL
SENTRY_ENVIRONMENT=                          # OPTIONAL — auto-detectado de NODE_ENV si vacío
SENTRY_RELEASE=                              # OPTIONAL — versión/git sha para tracking
SENTRY_TRACES_SAMPLE_RATE=0.1                # OPTIONAL — 0.0 a 1.0
SENTRY_PROFILES_SAMPLE_RATE=0.1              # OPTIONAL — 0.0 a 1.0
