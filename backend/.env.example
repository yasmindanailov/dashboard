# ============================================================================
# Variables de entorno — Backend (NestJS)
# ============================================================================
#
# Copia este archivo como `.env` y rellena los valores reales.
# El archivo `.env` está en .gitignore — nunca se commitea.
#
# Las variables marcadas como REQUIRED rompen el arranque si faltan.
# Las OPTIONAL tienen valor por defecto razonable.
# ============================================================================

# ── Server ──
PORT=3001                                   # OPTIONAL — puerto HTTP, default 3001
NODE_ENV=development                         # development | production | test
NEXT_PUBLIC_APP_URL=http://localhost:3002    # OPTIONAL — origen permitido en CORS

# ── Database (Prisma) ──
DATABASE_URL=postgresql://USER:PASS@localhost:5432/aelium_dashboard   # REQUIRED

# ── Redis (BullMQ + cache + rate limiting) ──
REDIS_URL=redis://localhost:6379             # REQUIRED
# ADR-016: deshabilita el rate limiting (ThrottlerGuard). Solo para E2E/local que
# itera logins desde una sola IP. NUNCA en producción.
# THROTTLER_DISABLED=true

# ── Auth ──
JWT_ACCESS_SECRET=cambiar-en-produccion      # REQUIRED — mínimo 32 chars
JWT_REFRESH_SECRET=cambiar-en-produccion     # REQUIRED — distinto del access
JWT_ACCESS_TTL=15m                           # OPTIONAL
JWT_REFRESH_TTL=7d                           # OPTIONAL

# ── Vault de secretos de plugins (Sprint 15A — ADR-080 §3) ──
# AES-256-GCM. Usado por SecretVaultService para cifrar `plugin_installs.secrets`
# (api keys, webhook secrets de proveedores externos: Stripe, Enhance CP,
# ResellerClub, etc.). Si la var falta o no es 64 hex chars, el backend NO
# arranca (fail-fast). Generar con:
#   openssl rand -hex 32
# Rotación: en Sprint 15A v1 hay una sola key activa. La rotación elegante
# (multi-key con `key_version`) se difiere a sub-sprint condicionado.
ENCRYPTION_KEY=                              # REQUIRED — 32 bytes en hex (64 chars)

# ── Email (SMTP — MailPit en dev, real en prod) ──
SMTP_HOST=localhost                          # REQUIRED
SMTP_PORT=1025                               # REQUIRED
SMTP_USER=                                   # OPTIONAL (vacío en MailPit local)
SMTP_PASS=                                   # OPTIONAL
SMTP_FROM=noreply@aelium.com                 # REQUIRED

# ── Plugin Enhance CP — seed dev/QA (Sprint 15C Fase 15C.J — ADR-083) ──
# Las 3 vars son OPTIONAL pero **conjuntas**: si las 3 están presentes,
# `pnpm seed` pre-crea el row `plugin_installs` para `enhance_cp` con
# `enabled=true` + secrets cifrados (DX para staging/dev sin abrir
# `/admin/settings/plugins` manualmente). Si alguna falta o el script
# corre con `NODE_ENV=production`, el seed skip silencioso.
# La fila ya creada NO se sobreescribe en re-seed (admin config gana).
ENHANCE_DEV_BASE_URL=                        # OPTIONAL — ej. https://enhance.lab.aelium.net
ENHANCE_DEV_MASTER_ORG_ID=                   # OPTIONAL — UUID del Master Org Aelium en Enhance
ENHANCE_DEV_API_TOKEN=                       # OPTIONAL — Super Admin token revocable

# ── Sentry (observabilidad de errores) ──
# Sin SENTRY_DSN definido → Sentry inactivo (no envía datos, no consume).
# Activar solo en staging/production. En dev local dejar vacío.
SENTRY_DSN=                                  # OPTIONAL
SENTRY_ENVIRONMENT=                          # OPTIONAL — auto-detectado de NODE_ENV si vacío
SENTRY_RELEASE=                              # OPTIONAL — versión/git sha para tracking
SENTRY_TRACES_SAMPLE_RATE=0.1                # OPTIONAL — 0.0 a 1.0
SENTRY_PROFILES_SAMPLE_RATE=0.1              # OPTIONAL — 0.0 a 1.0
