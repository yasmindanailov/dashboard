// ═══════════════════════════════════════════════
// Aelium Dashboard — Prisma Schema
// Generado desde DATABASE_SCHEMA.md
// ═══════════════════════════════════════════════

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── BLOQUE 1: USUARIOS Y AUTH ───

enum UserStatus {
  pending_verification
  active
  blocked
  inactive
}

enum RoleSlug {
  superadmin
  agent_full
  agent_billing
  agent_support
  client
  partner_pending
  partner
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        RoleSlug @unique
  name        String   @db.VarChar(100)
  description String?
  permissions Json     @default("[]")
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz()

  users User[]

  @@map("roles")
}

model User {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String     @unique @db.VarChar(255)
  password_hash      String     @db.VarChar(500)
  first_name         String     @db.VarChar(100)
  last_name          String     @db.VarChar(100)
  status             UserStatus @default(pending_verification)
  email_verified_at  DateTime?  @db.Timestamptz()
  login_attempts     Int        @default(0)
  blocked_until      DateTime?  @db.Timestamptz()
  last_login_at      DateTime?  @db.Timestamptz()
  last_login_ip      String?    @db.VarChar(45)
  two_factor_enabled Boolean    @default(false)
  two_factor_secret  String?    @db.VarChar(500)
  avatar_url         String?    @db.VarChar(1000)
  language           String     @default("es") @db.VarChar(5)
  timezone           String     @default("Europe/Madrid") @db.VarChar(50)
  role_id            String     @db.Uuid
  partner_id         String?    @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz()
  updated_at         DateTime   @default(now()) @updatedAt @db.Timestamptz()

  role                        Role                       @relation(fields: [role_id], references: [id])
  sessions                    Session[]
  email_verifications         EmailVerification[]
  password_resets             PasswordReset[]
  client_profile              ClientProfile?
  billing_profiles            BillingProfile[]
  invoices                    Invoice[]
  notifications_received      Notification[]             @relation("notification_recipient")
  conversations               Conversation[]             @relation("UserConversations")
  tasks_assigned              Task[]                     @relation("TaskAssignee")
  tasks_created               Task[]                     @relation("TaskCreator")
  tasks_as_client             Task[]                     @relation("TaskClient")
  checklist_completions       TaskChecklistCompletion[]  @relation("ChecklistCompleter")
  maintenance_logs_performed  MaintenanceLog[]           @relation("MaintenancePerformer")
  maintenance_logs_as_client  MaintenanceLog[]           @relation("ClientMaintenanceLogs")
  task_tags_created           TaskTag[]                  @relation("TaskTagCreator")
  client_notes_authored       ClientNote[]               @relation("ClientNoteAuthor")
  support_inside_subscription SupportInsideSubscription? @relation("UserSupportInsideSubscription")

  @@index([email])
  @@index([role_id])
  @@index([status])
  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  token_hash   String   @unique @db.VarChar(500)
  refresh_hash String   @unique @db.VarChar(500)
  ip_address   String   @db.VarChar(45)
  user_agent   String?  @db.VarChar(1000)
  device_label String?  @db.VarChar(200)
  is_active    Boolean  @default(true)
  last_used_at DateTime @default(now()) @db.Timestamptz()
  expires_at   DateTime @db.Timestamptz()
  created_at   DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_active])
  @@map("sessions")
}

model EmailVerification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(500)
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("email_verifications")
}

model PasswordReset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(500)
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  ip_address String    @db.VarChar(45)
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_resets")
}

// ─── BLOQUE 2: PERFIL DE CLIENTE ───

enum ClientType {
  individual
  company
}

model ClientProfile {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String     @unique @db.Uuid
  client_type        ClientType @default(individual)
  company_name       String?    @db.VarChar(300)
  tax_id             String?    @db.VarChar(20)
  phone              String?    @db.VarChar(20)
  address_line1      String?    @db.VarChar(500)
  address_line2      String?    @db.VarChar(500)
  city               String?    @db.VarChar(100)
  state              String?    @db.VarChar(100)
  postal_code        String?    @db.VarChar(10)
  country            String     @default("ES") @db.VarChar(2)
  billing_email      String?    @db.VarChar(255)
  notes_internal     String?
  stripe_customer_id String?    @db.VarChar(200)
  credit_balance     Decimal    @default(0) @db.Decimal(10, 2)
  metadata           Json?
  created_at         DateTime   @default(now()) @db.Timestamptz()
  updated_at         DateTime   @default(now()) @updatedAt @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

enum BillingProfileType {
  personal
  autonomo
  empresa
}

model BillingProfile {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String             @db.Uuid
  type          BillingProfileType
  label         String             @db.VarChar(100)
  first_name    String?            @db.VarChar(100)
  last_name     String?            @db.VarChar(100)
  company_name  String?            @db.VarChar(200)
  nif_cif       String?            @db.VarChar(20)
  address_line1 String             @db.VarChar(255)
  address_line2 String?            @db.VarChar(255)
  city          String             @db.VarChar(100)
  postal_code   String             @db.VarChar(20)
  country       String             @default("ES") @db.VarChar(2)
  is_default    Boolean            @default(false)
  created_at    DateTime           @default(now()) @db.Timestamptz()
  updated_at    DateTime           @default(now()) @updatedAt @db.Timestamptz()

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  services Service[]
  invoices Invoice[]

  @@index([user_id])
  @@map("billing_profiles")
}

// ─── BLOQUE 3: SETTINGS GLOBALES ───

model Setting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category    String   @db.VarChar(100)
  key         String   @db.VarChar(200)
  value       Json
  description String?
  updated_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@unique([category, key])
  @@index([category])
  @@map("settings")
}

// ─── BLOQUE 4: PRODUCTOS Y CATÁLOGO ───

enum BillingCycle {
  monthly
  quarterly
  semiannual
  annual
  one_time
}

enum ProductStatus {
  active
  inactive
  deprecated
}

enum ProductType {
  hosting_web // Plans: Web Inicio, Web Pro, Web Business
  domain // Independent product, free first year with annual hosting
  docker_service // Nextcloud, OpenClaw, etc. — template .yaml
  support_inside // Addon global de cuenta (Básico, Medium, Pro) — §7 DECISIONS.md
  we_do_it // Addon por producto (hosting, docker) — §8 DECISIONS.md
  custom_service // Proyectos manuales a escala (ERP, CRM) — §27 DECISIONS.md
}

// ProvisionerType: dinámico via plugin system (Sprint 8).
// Valores conocidos: enhance_cp, resellerclub, docker_engine, internal, manual.
// Se almacena como String para permitir registrar nuevos provisioners sin migraciones.

enum ExtraType {
  free_period
  discount
  included_product
}

enum ExtraApplicableCycle {
  monthly
  annual
  both
}

model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  parent_id   String?  @db.Uuid
  order_index Int      @default(0)
  active      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  parent   ProductCategory?  @relation("category_tree", fields: [parent_id], references: [id])
  children ProductCategory[] @relation("category_tree")
  products Product[]

  @@index([parent_id])
  @@map("product_categories")
}

model Product {
  id                        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id               String?       @db.Uuid
  name                      String        @db.VarChar(200)
  slug                      String        @unique @db.VarChar(200)
  description               String?
  short_description         String?       @db.VarChar(500)
  type                      ProductType
  provisioner               String        @default("manual") @db.VarChar(100)
  image_url                 String?       @db.VarChar(500)
  badge_text                String?       @db.VarChar(50)
  order_index               Int           @default(0)
  status                    ProductStatus @default(active)
  is_addon                  Boolean       @default(false)
  is_global_addon           Boolean       @default(false)
  requires_existing_product Boolean       @default(false)
  required_product_type     String?       @db.VarChar(50)
  max_quantity_per_client   Int?
  grace_period_days         Int           @default(0)
  suspension_days           Int           @default(7)
  cancellation_days         Int           @default(30)
  data_retention_days       Int           @default(30)
  client_can_pause          Boolean       @default(false)
  pause_max_days            Int?
  provisioner_config        Json?
  audit_event_types         Json?
  features                  Json?
  metadata                  Json?
  partner_commission_pct    Decimal?      @db.Decimal(5, 2)
  created_at                DateTime      @default(now()) @db.Timestamptz()
  updated_at                DateTime      @default(now()) @updatedAt @db.Timestamptz()

  category                     ProductCategory?            @relation(fields: [category_id], references: [id])
  pricing                      ProductPricing[]
  extras                       ProductExtra[]
  checklist_items              ProductChecklistItem[]
  services                     Service[]
  support_inside_config        SupportInsideConfig?        @relation("ProductSupportInsideConfig")
  support_inside_subscriptions SupportInsideSubscription[] @relation("ProductSupportInsideSubscriptions")

  @@index([category_id])
  @@index([type])
  @@index([status])
  @@map("products")
}

model ProductPricing {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id          String       @db.Uuid
  billing_cycle       BillingCycle
  price               Decimal      @db.Decimal(10, 2)
  setup_fee           Decimal      @default(0) @db.Decimal(10, 2)
  currency            String       @default("EUR") @db.VarChar(3)
  discount_percentage Decimal?     @db.Decimal(5, 2)
  active              Boolean      @default(true)
  created_at          DateTime     @default(now()) @db.Timestamptz()
  updated_at          DateTime     @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, billing_cycle, currency])
  @@map("product_pricing")
}

model ProductExtra {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id          String               @db.Uuid
  extra_product_id    String?              @db.Uuid
  type                ExtraType
  is_mandatory        Boolean              @default(false)
  label               String               @db.VarChar(200)
  discount_percentage Decimal?             @db.Decimal(5, 2)
  free_months         Int?
  max_value_eur       Decimal?             @db.Decimal(10, 2)
  applicable_cycles   ExtraApplicableCycle @default(annual)
  tld_restrictions    Json?
  valid_until         DateTime?            @db.Timestamptz()
  max_uses            Int?
  uses_count          Int                  @default(0)
  active              Boolean              @default(true)
  created_at          DateTime             @default(now()) @db.Timestamptz()
  updated_at          DateTime             @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_extras")
}

model ProductChecklistItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String   @db.Uuid
  label       String   @db.VarChar(200)
  order_index Int      @default(0)
  is_required Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_checklist_items")
}

// ─── BLOQUE 5: SERVICIOS ───

enum ServiceStatus {
  pending
  provisioning
  active
  suspended
  cancelled
  terminated
}

model Service {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String        @db.Uuid
  product_id          String        @db.Uuid
  billing_profile_id  String?       @db.Uuid
  partner_id          String?       @db.Uuid
  status              ServiceStatus @default(pending)
  label               String?       @db.VarChar(300)
  domain              String?       @db.VarChar(300)
  server_id           String?       @db.Uuid
  billing_cycle       BillingCycle  @default(monthly)
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("EUR") @db.VarChar(3)
  next_due_date       DateTime?     @db.Timestamptz()
  next_invoice_date   DateTime?     @db.Timestamptz()
  cancelled_at        DateTime?     @db.Timestamptz()
  cancellation_reason String?
  suspended_at        DateTime?     @db.Timestamptz()
  suspension_reason   String?
  paused_at           DateTime?     @db.Timestamptz()
  pause_max_date      DateTime?     @db.Timestamptz()
  // Sprint 11 Fase 11.B (ADR-077): denormalizado de `product.provisioner` al
  // provisionar. Inmutable tras `service.activated` — el plugin que provisionó
  // es el dueño del lifecycle aunque el admin cambie luego `product.provisioner`.
  provisioner_slug    String?       @db.VarChar(100)
  // Sprint 11 Fase 11.B (ADR-077 §2.2): ID del recurso en el sistema externo.
  // NULL para plugins `internal`/`manual`. Indexado para reconciliación cron.
  provider_reference  String?       @db.VarChar(500)
  provisioner_data    Json?
  metadata            Json?
  created_at          DateTime      @default(now()) @db.Timestamptz()
  updated_at          DateTime      @default(now()) @updatedAt @db.Timestamptz()

  product                     Product                    @relation(fields: [product_id], references: [id])
  billing_profile             BillingProfile?            @relation(fields: [billing_profile_id], references: [id])
  tasks                       Task[]                     @relation("TaskService")
  maintenance_logs            MaintenanceLog[]           @relation("ServiceMaintenanceLogs")
  checklist_items             ServiceChecklistItem[]     @relation("ServiceChecklistItems")
  support_inside_subscription SupportInsideSubscription? @relation("ServiceSupportInsideSubscription")
  support_inside_slots        SupportInsideSlot[]        @relation("ServiceSupportInsideSlots")

  @@index([user_id])
  @@index([product_id])
  @@index([billing_profile_id])
  @@index([status])
  @@index([next_due_date])
  // Sprint 11 Fase 11.B: provisioner_slug indexado para queries de
  // reconciliación cron y filtro admin (`/admin/services?provisioner=...`).
  @@index([provisioner_slug])
  // Sprint 11 Fase 11.B: provider_reference indexado para resolver el servicio
  // desde callbacks/webhooks del proveedor (`WHERE provider_reference = X`).
  @@index([provider_reference])
  @@map("services")
}

// ─── BLOQUE 6: FACTURACIÓN ───

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
  refunded
}

model Invoice {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_number     String        @unique @db.VarChar(50)
  user_id            String        @db.Uuid
  billing_profile_id String?       @db.Uuid
  partner_id         String?       @db.Uuid
  partner_label      String?       @db.VarChar(200)
  status             InvoiceStatus @default(draft)
  subtotal           Decimal       @db.Decimal(10, 2)
  tax_rate           Decimal       @default(21) @db.Decimal(5, 2)
  tax_amount         Decimal       @db.Decimal(10, 2)
  discount_amount    Decimal       @default(0) @db.Decimal(10, 2)
  total              Decimal       @db.Decimal(10, 2)
  currency           String        @default("EUR") @db.VarChar(3)
  due_date           DateTime      @db.Timestamptz()
  paid_at            DateTime?     @db.Timestamptz()
  payment_provider   String?       @db.VarChar(100) // Plugin: "stripe", "manual", etc.
  payment_method     String?       @db.VarChar(100) // "card", "sepa", "transfer"
  payment_ref        String?       @db.VarChar(500) // External ID from payment provider
  retry_count        Int           @default(0)
  max_retries        Int           @default(3)
  next_retry_at      DateTime?     @db.Timestamptz()
  is_manual          Boolean       @default(false)
  notes              String?
  pdf_url            String?       @db.VarChar(1000)
  metadata           Json?
  created_at         DateTime      @default(now()) @db.Timestamptz()
  updated_at         DateTime      @default(now()) @updatedAt @db.Timestamptz()

  items           InvoiceItem[]
  billing_profile BillingProfile? @relation(fields: [billing_profile_id], references: [id])
  user            User            @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([billing_profile_id])
  @@index([status])
  @@index([due_date])
  @@index([next_retry_at])
  @@map("invoices")
}

model InvoiceItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id   String    @db.Uuid
  service_id   String?   @db.Uuid
  product_id   String?   @db.Uuid
  description  String    @db.VarChar(500)
  quantity     Int       @default(1)
  unit_price   Decimal   @db.Decimal(10, 2)
  setup_fee    Decimal   @default(0) @db.Decimal(10, 2)
  discount_pct Decimal?  @db.Decimal(5, 2)
  total        Decimal   @db.Decimal(10, 2)
  period_start DateTime? @db.Timestamptz()
  period_end   DateTime? @db.Timestamptz()

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
  @@map("invoice_items")
}

// ─── BLOQUE 7: SUPPORT INSIDE ───

enum ConversationStatus {
  open
  waiting_client
  waiting_agent
  resolved
  closed
}

enum ConversationPriority {
  low
  normal
  high
  urgent
}

enum ConversationType {
  chat
  ticket
}

enum ConversationCategory {
  support_general
  support_billing
  support_technical
  wdify_progress
  wdify_feedback
  escalated_chat
}

model Conversation {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sequence_number    Int?                  @unique // Auto-assigned via PostgreSQL SEQUENCE on ticket creation
  type               ConversationType      @default(chat)
  user_id            String?               @db.Uuid
  assigned_agent_id  String?               @db.Uuid
  subject            String                @db.VarChar(500)
  status             ConversationStatus    @default(open)
  priority           ConversationPriority  @default(normal)
  category           ConversationCategory?
  channel            String                @default("web") @db.VarChar(50)
  is_ai_filtered     Boolean               @default(false)
  guest_name         String?               @db.VarChar(200) // Para anónimos en la landing
  guest_email        String?               @db.VarChar(255) // Para vincular al registrarse (7.5.1)
  guest_session_hash String?               @db.VarChar(500) // Hash SHA-256 del token de sesión guest
  service_id         String?               @db.Uuid
  escalated_from_id  String?               @db.Uuid
  tags               Json?
  closed_at          DateTime?             @db.Timestamptz()
  resolved_at        DateTime?             @db.Timestamptz()
  first_response_at  DateTime?             @db.Timestamptz()
  resolution_note    String?
  resolved_by_id     String?               @db.Uuid
  metadata           Json?
  created_at         DateTime              @default(now()) @db.Timestamptz()
  updated_at         DateTime              @default(now()) @updatedAt @db.Timestamptz()

  user           User?          @relation("UserConversations", fields: [user_id], references: [id])
  messages       Message[]
  escalated_from Conversation?  @relation("ConversationEscalation", fields: [escalated_from_id], references: [id])
  escalated_to   Conversation[] @relation("ConversationEscalation")

  @@index([user_id])
  @@index([assigned_agent_id])
  @@index([status])
  @@index([type])
  @@index([guest_email])
  @@index([guest_session_hash])
  @@map("conversations")
}

// ─── BLOQUE 7B: NOTAS ESTRUCTURADAS DEL CLIENTE ───

enum NoteCategory {
  conversation
  solution
  billing
  technical
  general
}

model ClientNote {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String       @db.Uuid
  author_id       String       @db.Uuid
  conversation_id String?      @db.Uuid
  task_id         String?      @db.Uuid
  category        NoteCategory @default(conversation)
  body            String
  is_pinned       Boolean      @default(false)
  created_at      DateTime     @default(now()) @db.Timestamptz()

  task   Task? @relation("TaskClientNotes", fields: [task_id], references: [id], onDelete: SetNull)
  // Sprint 8 Fase B.9 (2026-04-30) — relación inversa al autor (staff)
  // para enriquecer las notas con `first_name`/`last_name` sin segunda
  // query. Cliente y autor son ambos `users(id)`, distinguidos por
  // categoría: `user_id` = cliente al que pertenece la nota; `author_id`
  // = staff que la escribió. No se requiere migration SQL: el FK
  // `author_id` ya existe a nivel BD desde el seed inicial; sólo se
  // expone como navegación en el cliente Prisma generado.
  author User  @relation("ClientNoteAuthor", fields: [author_id], references: [id])

  @@index([user_id])
  @@index([conversation_id])
  @@index([task_id])
  @@map("client_notes")
}

enum MessageSender {
  client
  agent
  system
  ai
}

model Message {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String        @db.Uuid
  sender_type     MessageSender
  sender_id       String?       @db.Uuid
  body            String
  attachments     Json?
  is_internal     Boolean       @default(false)
  read_at         DateTime?     @db.Timestamptz()
  created_at      DateTime      @default(now()) @db.Timestamptz()

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("messages")
}

// ─── BLOQUE 8: TAREAS ───

// Sprint 8 Fase B.7 (2026-04-29) — ADR-073 renombra `wow_call` → `contact_client`.
// El enum representa qué bloque/automatización activa la tarea, no la intención
// del agente. La intención humana ("Bienvenida primer servicio", "Renovación
// hosting", etc.) vive en `Task.reason` (texto libre <=100) + tags asignables
// extensibles en `task_tags`.
//
// Sprint 8 Fase B.10 (2026-04-30) — ADR-074 añade `support_ticket`.
// Tareas creadas automáticamente por `SupportTicketTaskCreatorListener`
// al asignar un ticket. SIEMPRE tienen `conversation_id` poblado (FK a
// `Conversation`). El cierre delega en el módulo support para
// notificación canónica al cliente — ver ADR-074 §"Reglas canónicas".
enum TaskType {
  contact_client
  maintenance
  maintenance_management
  project_task
  custom_work
  support_setup
  support_ticket
}

enum TaskStatus {
  pending
  in_progress
  completed
  not_completed_in_time
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  critical
}

model Task {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            TaskType
  title           String       @db.VarChar(500)
  description     String?
  status          TaskStatus   @default(pending)
  priority        TaskPriority @default(medium)
  assigned_to     String?      @db.Uuid
  created_by      String       @db.Uuid
  client_id       String       @db.Uuid
  service_id      String?      @db.Uuid
  conversation_id String?      @db.Uuid
  client_note     String?
  due_date        DateTime?    @db.Timestamptz()
  completed_at    DateTime?    @db.Timestamptz()
  is_recurring    Boolean      @default(false)
  recurrence_day  Int?
  billing_month   String?      @db.VarChar(7)
  // Sprint 8 Fase B.7 (2026-04-29) — ADR-073. POR QUÉ humano de la tarea
  // ("Bienvenida primer servicio", "Renovación próxima", etc.). Texto libre
  // opcional. Visible en el detalle bajo el título y truncado a 60 chars en
  // el tablero. Indexable para futura búsqueda full-text.
  reason          String?      @db.VarChar(100)
  metadata        Json?
  created_at      DateTime     @default(now()) @db.Timestamptz()
  updated_at      DateTime     @default(now()) @updatedAt @db.Timestamptz()

  assignee              User?                     @relation("TaskAssignee", fields: [assigned_to], references: [id])
  creator               User                      @relation("TaskCreator", fields: [created_by], references: [id])
  client                User                      @relation("TaskClient", fields: [client_id], references: [id])
  service               Service?                  @relation("TaskService", fields: [service_id], references: [id], onDelete: SetNull)
  checklist_completions TaskChecklistCompletion[] @relation("TaskChecklistCompletions")
  maintenance_log       MaintenanceLog?           @relation("TaskMaintenanceLog")
  structured_notes      ClientNote[]              @relation("TaskClientNotes")
  tag_assignments       TaskTagAssignment[]       @relation("TaskTagAssignments")

  @@unique([service_id, billing_month, type], name: "uniq_task_maintenance_per_month", map: "tasks_uniq_maintenance_per_month")
  @@index([assigned_to])
  @@index([status])
  @@index([client_id])
  @@index([due_date])
  @@index([billing_month])
  @@map("tasks")
}

// ─── BLOQUE 8B BIS: TAGS DE TAREAS ───
// Sprint 8 Fase B.7 (2026-04-29) — ADR-073. Etiquetas extensibles asignables
// por staff con `Manage.Task`. Crear/borrar etiquetas requiere `Manage.TaskTag`
// (superadmin + agent_full). Clientes/partners NO ven tags. M2M explícita
// para que CASL filtre por tag y para que la UI pueda mostrar metadatos
// (color, fecha de creación) sin queries adicionales.
model TaskTag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug       String   @unique @db.VarChar(50)
  label      String   @db.VarChar(50)
  color      String?  @db.VarChar(7)
  created_at DateTime @default(now()) @db.Timestamptz()
  created_by String?  @db.Uuid

  creator     User?               @relation("TaskTagCreator", fields: [created_by], references: [id])
  assignments TaskTagAssignment[] @relation("TagAssignments")

  @@map("task_tags")
}

model TaskTagAssignment {
  task_id     String   @db.Uuid
  tag_id      String   @db.Uuid
  assigned_at DateTime @default(now()) @db.Timestamptz()

  task Task    @relation("TaskTagAssignments", fields: [task_id], references: [id], onDelete: Cascade)
  tag  TaskTag @relation("TagAssignments", fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([task_id, tag_id])
  @@index([tag_id])
  @@map("task_tag_assignments")
}

// ─── BLOQUE 8B: TAREAS — CHECKLIST + MANTENIMIENTO ───
// Sprint 8 Fase A (2026-04-29). ADR-061 (Support Inside) + plan Sprint 8 §3.4.

enum ChecklistItemKind {
  product
  service
}

model TaskChecklistCompletion {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id      String            @db.Uuid
  item_id      String            @db.Uuid
  item_kind    ChecklistItemKind
  completed_by String            @db.Uuid
  completed_at DateTime          @default(now()) @db.Timestamptz()
  notes        String?

  task      Task @relation("TaskChecklistCompletions", fields: [task_id], references: [id], onDelete: Cascade)
  completer User @relation("ChecklistCompleter", fields: [completed_by], references: [id])

  @@unique([task_id, item_id, item_kind], name: "uniq_completion_per_item", map: "task_checklist_completions_uniq")
  @@index([task_id])
  @@index([item_id, item_kind])
  @@map("task_checklist_completions")
}

model MaintenanceLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id      String   @unique @db.Uuid
  service_id   String   @db.Uuid
  client_id    String   @db.Uuid
  month_year   String   @db.VarChar(7)
  notes        String
  performed_by String   @db.Uuid
  performed_at DateTime @default(now()) @db.Timestamptz()
  metadata     Json?

  task      Task    @relation("TaskMaintenanceLog", fields: [task_id], references: [id], onDelete: Cascade)
  service   Service @relation("ServiceMaintenanceLogs", fields: [service_id], references: [id], onDelete: Cascade)
  client    User    @relation("ClientMaintenanceLogs", fields: [client_id], references: [id])
  performer User    @relation("MaintenancePerformer", fields: [performed_by], references: [id])

  @@index([service_id])
  @@index([month_year])
  @@index([client_id])
  @@map("maintenance_logs")
}

model ServiceChecklistItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id       String   @db.Uuid
  item_template_id String?  @db.Uuid
  label            String   @db.VarChar(300)
  is_required      Boolean  @default(false)
  order_index      Int      @default(0)
  created_at       DateTime @default(now()) @db.Timestamptz()

  service Service @relation("ServiceChecklistItems", fields: [service_id], references: [id], onDelete: Cascade)

  @@index([service_id])
  @@map("service_checklist_items")
}

// ─── BLOQUE 8C: SUPPORT INSIDE (Sprint 8 Fase D — ADR-034 + ADR-061 + ADR-075) ───
// Schema de Support Inside como tier de cuenta con UX dedicada. El producto
// Support Inside vive en `products` con type=support_inside (ADR-034); aquí
// se añade su configuración 1:1, las suscripciones de cliente, y los slots
// asignados a servicios concretos.
//
// Doctrina canónica:
//   - 1 cliente puede tener máx. 1 suscripción activa (ADR-034 + EC-T8-09).
//   - 1 servicio puede tener máx. 1 slot activo (released_at IS NULL).
//     Validado en service layer (Postgres no permite UNIQUE parcial WHERE
//     en Prisma sin SQL raw).
//   - La suscripción genera un Service estándar (ADR-061: reusa todo el
//     motor de billing/cancelación/prorrateo) — `subscription.service_id`
//     apunta al service de la propia subscription en `services`.

enum SupportInsideSlotType {
  maintenance
  maintenance_management
}

enum SupportInsideSubscriptionStatus {
  active
  cancelled
  paused
}

enum SupportInsideChannel {
  webchat
  email
  phone
  whatsapp
}

enum SupportInsidePriorityTier {
  standard
  high
  max
}

enum SupportInsideCtaVisibility {
  hidden
  catalog_banner
  landing_cta
}

// Configuración 1:1 del producto Support Inside. Editable desde el editor
// dedicado `/admin/support-inside-plans/<slug>` (ADR-075). Las secciones
// del editor mapean directamente a campos aquí — añadir campo nuevo en
// sprint futuro = añadir columna + sección card sin tocar las anteriores.
model SupportInsideConfig {
  id                 String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id         String                     @unique @db.Uuid
  // Sección "Slots y capacidades" del editor (ADR-075 §B.2).
  slots_included     Int                        @default(0)
  slot_types_allowed SupportInsideSlotType[]
  /// Sub-fase 8.D.12.fix (2026-05-01): tipos de producto a los que el plan
  /// permite asignar slots de mantenimiento. Default `[hosting_web,
  /// docker_service]` — los servicios técnicos cuyo mantenimiento tiene
  /// sentido operativo. Excluye `domain` (no se mantiene), `support_inside`
  /// (defense in depth contra el bug de auto-asignación), y `we_do_it` /
  /// `custom_service` (futuros, decidir al introducirlos).
  /// Empty array = sin restricciones (legacy / migración).
  applicable_product_types ProductType[]
  extra_slot_price   Decimal                    @default(0) @db.Decimal(10, 2)
  // Sección "Soporte y canales".
  channels_active    SupportInsideChannel[]
  priority_tier      SupportInsidePriorityTier  @default(standard)
  response_sla_hours Int                        @default(24)
  // Sección "Configuración avanzada".
  cta_visibility     SupportInsideCtaVisibility @default(hidden)
  // Metadata libre por si alguna sección futura necesita campos no
  // estructurados antes de promocionarlos a columna real.
  metadata           Json?
  created_at         DateTime                   @default(now()) @db.Timestamptz()
  updated_at         DateTime                   @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation("ProductSupportInsideConfig", fields: [product_id], references: [id], onDelete: Cascade)

  @@map("support_inside_config")
}

model SupportInsideSubscription {
  id                  String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id           String                          @unique @db.Uuid
  product_id          String                          @db.Uuid
  service_id          String                          @unique @db.Uuid
  status              SupportInsideSubscriptionStatus @default(active)
  started_at          DateTime                        @default(now()) @db.Timestamptz()
  cancelled_at        DateTime?                       @db.Timestamptz()
  cancellation_reason String?
  metadata            Json?
  created_at          DateTime                        @default(now()) @db.Timestamptz()
  updated_at          DateTime                        @default(now()) @updatedAt @db.Timestamptz()

  client  User                @relation("UserSupportInsideSubscription", fields: [client_id], references: [id], onDelete: Restrict)
  product Product             @relation("ProductSupportInsideSubscriptions", fields: [product_id], references: [id])
  service Service             @relation("ServiceSupportInsideSubscription", fields: [service_id], references: [id], onDelete: Restrict)
  slots   SupportInsideSlot[] @relation("SubscriptionSlots")

  @@index([client_id])
  @@index([product_id])
  @@index([status])
  @@map("support_inside_subscriptions")
}

model SupportInsideSlot {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id  String                @db.Uuid
  service_id       String                @db.Uuid
  slot_type        SupportInsideSlotType
  is_extra         Boolean               @default(false)
  extra_pricing_id String?               @db.Uuid
  assigned_at      DateTime              @default(now()) @db.Timestamptz()
  released_at      DateTime?             @db.Timestamptz()
  /// Día del mes (1-28) en que el cron diario `maintenance-monthly` dispara la tarea de mantenimiento del slot.
  /// CHECK 1..28 evita problemas con febrero (ADR-034 §recurrencia, sub-fase 8.D.12.1).
  /// Se computa al asignar el slot: LEAST(EXTRACT(DAY FROM assigned_at), 28).
  anniversary_day  Int
  metadata         Json?
  created_at       DateTime              @default(now()) @db.Timestamptz()

  subscription SupportInsideSubscription @relation("SubscriptionSlots", fields: [subscription_id], references: [id], onDelete: Cascade)
  service      Service                   @relation("ServiceSupportInsideSlots", fields: [service_id], references: [id], onDelete: Restrict)

  @@index([subscription_id])
  @@index([service_id])
  @@index([released_at])
  @@index([anniversary_day])
  @@map("support_inside_slots")
}

// ─── BLOQUE 9: NOTIFICACIONES ───

enum NotificationChannel {
  internal
  email
  whatsapp
  push
}

model Notification {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String              @db.Uuid
  channel    NotificationChannel @default(internal)
  title      String              @db.VarChar(300)
  body       String
  action_url String?             @db.VarChar(1000)
  read_at    DateTime?           @db.Timestamptz()
  sent_at    DateTime?           @db.Timestamptz()
  metadata   Json?
  created_at DateTime            @default(now()) @db.Timestamptz()

  user User @relation("notification_recipient", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([read_at])
  @@map("notifications")
}

model NotificationTemplate {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type String              @db.VarChar(100)
  channel    NotificationChannel
  locale     String              @default("es") @db.VarChar(10)
  subject    String              @db.VarChar(300)
  body       String
  variables  Json
  active     Boolean             @default(true)
  updated_by String?             @db.Uuid
  created_at DateTime            @default(now()) @db.Timestamptz()
  updated_at DateTime            @updatedAt @db.Timestamptz()

  @@unique([event_type, channel, locale])
  @@index([event_type])
  @@map("notification_templates")
}

// ─── BLOQUE 10: INFRAESTRUCTURA ───

enum ServerStatus {
  online
  offline
  maintenance
}

model Server {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String       @db.VarChar(200)
  hostname        String       @db.VarChar(500)
  ip_address      String       @db.VarChar(45)
  status          ServerStatus @default(online)
  provider        String?      @db.VarChar(100)
  location        String?      @db.VarChar(100)
  total_ram_mb    Int?
  total_disk_mb   Int?
  total_cpu_cores Int?
  allocated_ram   Int          @default(0)
  allocated_disk  Int          @default(0)
  allocated_cpu   Int          @default(0)
  ssh_port        Int          @default(22)
  credentials     String?
  notes           String?
  metadata        Json?
  created_at      DateTime     @default(now()) @db.Timestamptz()
  updated_at      DateTime     @default(now()) @updatedAt @db.Timestamptz()

  @@map("servers")
}

// ─── BLOQUE 11: EVENTOS Y OUTBOX ───

enum EventStatus {
  pending
  processing
  done
  failed
}

model EventOutbox {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type    String      @db.VarChar(200)
  payload       Json
  status        EventStatus @default(pending)
  retry_count   Int         @default(0)
  max_retries   Int         @default(5)
  last_error    String?
  processed_at  DateTime?   @db.Timestamptz()
  next_retry_at DateTime?   @db.Timestamptz()
  created_at    DateTime    @default(now()) @db.Timestamptz()

  @@index([status, next_retry_at])
  @@index([created_at])
  @@map("event_outbox")
}

// ─── BLOQUE 12: ERROR LOG ───

model ErrorLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level          String   @default("error") @db.VarChar(20)
  module         String   @db.VarChar(100)
  message        String
  stack_trace    String?
  correlation_id String?  @db.VarChar(100)
  user_id        String?  @db.Uuid
  request_path   String?  @db.VarChar(1000)
  request_method String?  @db.VarChar(10)
  metadata       Json?
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([module])
  @@index([level])
  @@index([correlation_id])
  @@index([created_at])
  @@map("error_log")
}

// ─── AUDIT SCHEMA (solo INSERT) ───

model AuditAccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  action     String   @db.VarChar(100)
  ip_address String   @db.VarChar(45)
  user_agent String?  @db.VarChar(1000)
  resource   String?  @db.VarChar(200)
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_access_log")
}

model AuditChangeLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?  @db.Uuid
  entity_type    String   @db.VarChar(100)
  entity_id      String   @db.Uuid
  action         String   @db.VarChar(50)
  changes_before Json?
  changes_after  Json?
  correlation_id String?  @db.VarChar(100)
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([entity_type, entity_id])
  @@index([user_id])
  @@index([created_at])
  @@map("audit_change_log")
}

// ─── BLOQUE 13: DLQ — JOBS FALLIDOS (Sprint 9 Fase A — ADR-063) ───

enum FailedJobStatus {
  failed
  retrying
  resolved
}

model FailedJob {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bull_job_id   String          @db.VarChar(200)
  queue         String          @db.VarChar(100)
  name          String          @db.VarChar(200)
  payload       Json
  last_error    String
  stack_trace   String?
  attempts_made Int
  retried_at    DateTime?       @db.Timestamptz()
  retried_by    String?         @db.Uuid
  status        FailedJobStatus @default(failed)
  created_at    DateTime        @default(now()) @db.Timestamptz()

  @@index([queue, status])
  @@index([created_at])
  @@map("failed_jobs")
}
