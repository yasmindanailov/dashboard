// ═══════════════════════════════════════════════
// Aelium Dashboard — Prisma Schema
// Generado desde DATABASE_SCHEMA.md
// ═══════════════════════════════════════════════

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── BLOQUE 1: USUARIOS Y AUTH ───

enum UserStatus {
  pending_verification
  active
  blocked
  inactive
}

enum RoleSlug {
  superadmin
  agent_full
  agent_billing
  agent_support
  client
  partner_pending
  partner
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        RoleSlug @unique
  name        String   @db.VarChar(100)
  description String?
  permissions Json     @default("[]")
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz()

  users User[]

  @@map("roles")
}

model User {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String     @unique @db.VarChar(255)
  password_hash         String     @db.VarChar(500)
  first_name            String     @db.VarChar(100)
  last_name             String     @db.VarChar(100)
  status                UserStatus @default(pending_verification)
  email_verified_at     DateTime?  @db.Timestamptz()
  login_attempts        Int        @default(0)
  blocked_until         DateTime?  @db.Timestamptz()
  last_login_at         DateTime?  @db.Timestamptz()
  last_login_ip         String?    @db.VarChar(45)
  two_factor_enabled    Boolean    @default(false)
  two_factor_secret     String?    @db.VarChar(500)
  avatar_url            String?    @db.VarChar(1000)
  language              String     @default("es") @db.VarChar(5)
  timezone              String     @default("Europe/Madrid") @db.VarChar(50)
  role_id               String     @db.Uuid
  partner_id            String?    @db.Uuid
  created_at            DateTime   @default(now()) @db.Timestamptz()
  updated_at            DateTime   @default(now()) @updatedAt @db.Timestamptz()

  role                  Role       @relation(fields: [role_id], references: [id])
  sessions              Session[]
  email_verifications   EmailVerification[]
  password_resets       PasswordReset[]
  client_profile        ClientProfile?
  billing_profiles      BillingProfile[]
  notifications_received Notification[] @relation("notification_recipient")

  @@index([email])
  @@index([role_id])
  @@index([status])
  @@map("users")
}

model Session {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  token_hash     String    @unique @db.VarChar(500)
  refresh_hash   String    @unique @db.VarChar(500)
  ip_address     String    @db.VarChar(45)
  user_agent     String?   @db.VarChar(1000)
  device_label   String?   @db.VarChar(200)
  is_active      Boolean   @default(true)
  last_used_at   DateTime  @default(now()) @db.Timestamptz()
  expires_at     DateTime  @db.Timestamptz()
  created_at     DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_active])
  @@map("sessions")
}

model EmailVerification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(500)
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("email_verifications")
}

model PasswordReset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(500)
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  ip_address String    @db.VarChar(45)
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_resets")
}

// ─── BLOQUE 2: PERFIL DE CLIENTE ───

enum ClientType {
  individual
  company
}

model ClientProfile {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String     @unique @db.Uuid
  client_type       ClientType @default(individual)
  company_name      String?    @db.VarChar(300)
  tax_id            String?    @db.VarChar(20)
  phone             String?    @db.VarChar(20)
  address_line1     String?    @db.VarChar(500)
  address_line2     String?    @db.VarChar(500)
  city              String?    @db.VarChar(100)
  state             String?    @db.VarChar(100)
  postal_code       String?    @db.VarChar(10)
  country           String     @default("ES") @db.VarChar(2)
  billing_email     String?    @db.VarChar(255)
  notes_internal    String?
  stripe_customer_id String?   @db.VarChar(200)
  credit_balance    Decimal    @default(0) @db.Decimal(10, 2)
  metadata          Json?
  created_at        DateTime   @default(now()) @db.Timestamptz()
  updated_at        DateTime   @default(now()) @updatedAt @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

enum BillingProfileType {
  personal
  autonomo
  empresa
}

model BillingProfile {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String             @db.Uuid
  type         BillingProfileType
  label        String             @db.VarChar(100)
  first_name   String?            @db.VarChar(100)
  last_name    String?            @db.VarChar(100)
  company_name String?            @db.VarChar(200)
  nif_cif      String?            @db.VarChar(20)
  address_line1 String            @db.VarChar(255)
  address_line2 String?           @db.VarChar(255)
  city         String             @db.VarChar(100)
  postal_code  String             @db.VarChar(20)
  country      String             @default("ES") @db.VarChar(2)
  is_default   Boolean            @default(false)
  created_at   DateTime           @default(now()) @db.Timestamptz()
  updated_at   DateTime           @default(now()) @updatedAt @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("billing_profiles")
}

// ─── BLOQUE 3: SETTINGS GLOBALES ───

model Setting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category    String   @db.VarChar(100)
  key         String   @db.VarChar(200)
  value       Json
  description String?
  updated_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@unique([category, key])
  @@index([category])
  @@map("settings")
}

// ─── BLOQUE 4: PRODUCTOS Y CATÁLOGO ───

enum BillingCycle {
  monthly
  quarterly
  semiannual
  annual
  one_time
}

enum ProductStatus {
  active
  inactive
  deprecated
}

enum ProductCategory {
  hosting_web
  hosting_agency
  domain
  cloud_office
  docker_service
  support_inside
  we_do_it
  development
}

model Product {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String          @db.VarChar(300)
  slug                   String          @unique @db.VarChar(300)
  category               ProductCategory
  description            String?
  short_description      String?         @db.VarChar(500)
  status                 ProductStatus   @default(active)
  is_addon               Boolean         @default(false)
  requires_product_id    String?         @db.Uuid
  billing_cycle          BillingCycle    @default(monthly)
  price                  Decimal         @db.Decimal(10, 2)
  setup_fee              Decimal         @default(0) @db.Decimal(10, 2)
  renewal_price          Decimal?        @db.Decimal(10, 2)
  cost_price             Decimal?        @db.Decimal(10, 2)
  currency               String          @default("EUR") @db.VarChar(3)
  trial_days             Int             @default(0)
  provisioner_plugin     String?         @db.VarChar(100)
  provisioner_config     Json?
  sort_order             Int             @default(0)
  features               Json?
  metadata               Json?
  partner_commission_pct Decimal?        @db.Decimal(5, 2)
  created_at             DateTime        @default(now()) @db.Timestamptz()
  updated_at             DateTime        @default(now()) @updatedAt @db.Timestamptz()

  requires_product Product?  @relation("product_addon", fields: [requires_product_id], references: [id])
  dependent_addons Product[] @relation("product_addon")
  services         Service[]

  @@index([category])
  @@index([status])
  @@map("products")
}

// ─── BLOQUE 5: SERVICIOS ───

enum ServiceStatus {
  pending
  provisioning
  active
  suspended
  cancelled
  terminated
}

model Service {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String        @db.Uuid
  product_id          String        @db.Uuid
  partner_id          String?       @db.Uuid
  status              ServiceStatus @default(pending)
  label               String?       @db.VarChar(300)
  domain              String?       @db.VarChar(300)
  server_id           String?       @db.Uuid
  billing_cycle       BillingCycle  @default(monthly)
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("EUR") @db.VarChar(3)
  next_due_date       DateTime?     @db.Timestamptz()
  next_invoice_date   DateTime?     @db.Timestamptz()
  cancelled_at        DateTime?     @db.Timestamptz()
  cancellation_reason String?
  suspended_at        DateTime?     @db.Timestamptz()
  suspension_reason   String?
  provisioner_data    Json?
  metadata            Json?
  created_at          DateTime      @default(now()) @db.Timestamptz()
  updated_at          DateTime      @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id])

  @@index([user_id])
  @@index([product_id])
  @@index([status])
  @@index([next_due_date])
  @@map("services")
}

// ─── BLOQUE 6: FACTURACIÓN ───

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
  refunded
}

model Invoice {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_number   String        @unique @db.VarChar(50)
  user_id          String        @db.Uuid
  partner_id       String?       @db.Uuid
  partner_label    String?       @db.VarChar(200)
  status           InvoiceStatus @default(draft)
  subtotal         Decimal       @db.Decimal(10, 2)
  tax_rate         Decimal       @default(21) @db.Decimal(5, 2)
  tax_amount       Decimal       @db.Decimal(10, 2)
  discount_amount  Decimal       @default(0) @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  currency         String        @default("EUR") @db.VarChar(3)
  due_date         DateTime      @db.Timestamptz()
  paid_at          DateTime?     @db.Timestamptz()
  payment_method   String?       @db.VarChar(100)
  payment_ref      String?       @db.VarChar(500)
  notes            String?
  pdf_url          String?       @db.VarChar(1000)
  metadata         Json?
  created_at       DateTime      @default(now()) @db.Timestamptz()
  updated_at       DateTime      @default(now()) @updatedAt @db.Timestamptz()

  items InvoiceItem[]

  @@index([user_id])
  @@index([status])
  @@index([due_date])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id  String  @db.Uuid
  service_id  String? @db.Uuid
  product_id  String? @db.Uuid
  description String  @db.VarChar(500)
  quantity    Int     @default(1)
  unit_price  Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  period_start DateTime? @db.Timestamptz()
  period_end   DateTime? @db.Timestamptz()

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
  @@map("invoice_items")
}

// ─── BLOQUE 7: SUPPORT INSIDE ───

enum ConversationStatus {
  open
  waiting_client
  waiting_agent
  resolved
  closed
}

enum ConversationPriority {
  low
  normal
  high
  urgent
}

model Conversation {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?              @db.Uuid
  assigned_agent_id   String?              @db.Uuid
  subject             String               @db.VarChar(500)
  status              ConversationStatus   @default(open)
  priority            ConversationPriority @default(normal)
  channel             String               @default("web") @db.VarChar(50)
  is_ai_filtered      Boolean              @default(false)
  guest_session_hash  String?              @db.VarChar(500)
  service_id          String?              @db.Uuid
  tags                Json?
  closed_at           DateTime?            @db.Timestamptz()
  resolved_at         DateTime?            @db.Timestamptz()
  first_response_at   DateTime?            @db.Timestamptz()
  metadata            Json?
  created_at          DateTime             @default(now()) @db.Timestamptz()
  updated_at          DateTime             @default(now()) @updatedAt @db.Timestamptz()

  messages Message[]

  @@index([user_id])
  @@index([assigned_agent_id])
  @@index([status])
  @@map("conversations")
}

enum MessageSender {
  client
  agent
  system
  ai
}

model Message {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String        @db.Uuid
  sender_type     MessageSender
  sender_id       String?       @db.Uuid
  body            String
  attachments     Json?
  is_internal     Boolean       @default(false)
  read_at         DateTime?     @db.Timestamptz()
  created_at      DateTime      @default(now()) @db.Timestamptz()

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("messages")
}

// ─── BLOQUE 8: TAREAS ───

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

model Task {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String       @db.VarChar(500)
  description     String?
  status          TaskStatus   @default(pending)
  priority        TaskPriority @default(normal)
  assigned_to     String?      @db.Uuid
  created_by      String       @db.Uuid
  user_id         String?      @db.Uuid
  service_id      String?      @db.Uuid
  conversation_id String?      @db.Uuid
  due_date        DateTime?    @db.Timestamptz()
  completed_at    DateTime?    @db.Timestamptz()
  tags            Json?
  metadata        Json?
  created_at      DateTime     @default(now()) @db.Timestamptz()
  updated_at      DateTime     @default(now()) @updatedAt @db.Timestamptz()

  @@index([assigned_to])
  @@index([status])
  @@index([user_id])
  @@map("tasks")
}

// ─── BLOQUE 9: NOTIFICACIONES ───

enum NotificationChannel {
  internal
  email
  whatsapp
  push
}

model Notification {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String              @db.Uuid
  channel      NotificationChannel @default(internal)
  title        String              @db.VarChar(300)
  body         String
  action_url   String?             @db.VarChar(1000)
  read_at      DateTime?           @db.Timestamptz()
  sent_at      DateTime?           @db.Timestamptz()
  metadata     Json?
  created_at   DateTime            @default(now()) @db.Timestamptz()

  user User @relation("notification_recipient", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([read_at])
  @@map("notifications")
}

// ─── BLOQUE 10: INFRAESTRUCTURA ───

enum ServerStatus {
  online
  offline
  maintenance
}

model Server {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String       @db.VarChar(200)
  hostname        String       @db.VarChar(500)
  ip_address      String       @db.VarChar(45)
  status          ServerStatus @default(online)
  provider        String?      @db.VarChar(100)
  location        String?      @db.VarChar(100)
  total_ram_mb    Int?
  total_disk_mb   Int?
  total_cpu_cores Int?
  allocated_ram   Int          @default(0)
  allocated_disk  Int          @default(0)
  allocated_cpu   Int          @default(0)
  ssh_port        Int          @default(22)
  credentials     String?
  notes           String?
  metadata        Json?
  created_at      DateTime     @default(now()) @db.Timestamptz()
  updated_at      DateTime     @default(now()) @updatedAt @db.Timestamptz()

  @@map("servers")
}

// ─── BLOQUE 11: EVENTOS Y OUTBOX ───

enum EventStatus {
  pending
  processing
  done
  failed
}

model EventOutbox {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type    String      @db.VarChar(200)
  payload       Json
  status        EventStatus @default(pending)
  retry_count   Int         @default(0)
  max_retries   Int         @default(5)
  last_error    String?
  processed_at  DateTime?   @db.Timestamptz()
  created_at    DateTime    @default(now()) @db.Timestamptz()

  @@index([status])
  @@index([created_at])
  @@map("event_outbox")
}

// ─── BLOQUE 12: ERROR LOG ───

model ErrorLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level           String   @default("error") @db.VarChar(20)
  module          String   @db.VarChar(100)
  message         String
  stack_trace     String?
  correlation_id  String?  @db.VarChar(100)
  user_id         String?  @db.Uuid
  request_path    String?  @db.VarChar(1000)
  request_method  String?  @db.VarChar(10)
  metadata        Json?
  created_at      DateTime @default(now()) @db.Timestamptz()

  @@index([module])
  @@index([level])
  @@index([correlation_id])
  @@index([created_at])
  @@map("error_log")
}

// ─── AUDIT SCHEMA (solo INSERT) ───

model AuditAccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  action     String   @db.VarChar(100)
  ip_address String   @db.VarChar(45)
  user_agent String?  @db.VarChar(1000)
  resource   String?  @db.VarChar(200)
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_access_log")
}

model AuditChangeLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?  @db.Uuid
  entity_type    String   @db.VarChar(100)
  entity_id      String   @db.Uuid
  action         String   @db.VarChar(50)
  changes_before Json?
  changes_after  Json?
  correlation_id String?  @db.VarChar(100)
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([entity_type, entity_id])
  @@index([user_id])
  @@index([created_at])
  @@map("audit_change_log")
}
