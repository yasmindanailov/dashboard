// ═══════════════════════════════════════════════
// Aelium Dashboard — Prisma Schema
// Generado desde DATABASE_SCHEMA.md
// ═══════════════════════════════════════════════

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── BLOQUE 1: USUARIOS Y AUTH ───

enum UserStatus {
  pending_verification
  active
  blocked
  inactive
}

enum RoleSlug {
  superadmin
  agent_full
  agent_billing
  agent_support
  client
  partner_pending
  partner
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        RoleSlug @unique
  name        String   @db.VarChar(100)
  description String?
  permissions Json     @default("[]")
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz()

  users User[]

  @@map("roles")
}

model User {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String     @unique @db.VarChar(255)
  password_hash      String     @db.VarChar(500)
  first_name         String     @db.VarChar(100)
  last_name          String     @db.VarChar(100)
  status             UserStatus @default(pending_verification)
  email_verified_at  DateTime?  @db.Timestamptz()
  login_attempts     Int        @default(0)
  blocked_until      DateTime?  @db.Timestamptz()
  last_login_at      DateTime?  @db.Timestamptz()
  last_login_ip      String?    @db.VarChar(45)
  two_factor_enabled Boolean    @default(false)
  two_factor_secret  String?    @db.VarChar(500)
  avatar_url         String?    @db.VarChar(1000)
  language           String     @default("es") @db.VarChar(5)
  timezone           String     @default("Europe/Madrid") @db.VarChar(50)
  role_id            String     @db.Uuid
  partner_id         String?    @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz()
  updated_at         DateTime   @default(now()) @updatedAt @db.Timestamptz()

  role                        Role                       @relation(fields: [role_id], references: [id])
  sessions                    Session[]
  email_verifications         EmailVerification[]
  password_resets             PasswordReset[]
  client_profile              ClientProfile?
  billing_profiles            BillingProfile[]
  invoices                    Invoice[]
  notifications_received      Notification[]             @relation("notification_recipient")
  conversations               Conversation[]             @relation("UserConversations")
  tasks_assigned              Task[]                     @relation("TaskAssignee")
  tasks_as_client             Task[]                     @relation("TaskClient")
  tasks_completed             Task[]                     @relation("TaskCompleter")
  checklist_completions       TaskChecklistCompletion[]  @relation("ChecklistCompleter")
  maintenance_logs_performed  MaintenanceLog[]           @relation("MaintenancePerformer")
  maintenance_logs_as_client  MaintenanceLog[]           @relation("ClientMaintenanceLogs")
  client_notes                ClientNote[]               @relation("ClientNoteUser")
  client_notes_authored       ClientNote[]               @relation("ClientNoteAuthor")
  support_inside_subscription SupportInsideSubscription? @relation("UserSupportInsideSubscription")
  enhance_customer            EnhanceCustomer?           @relation("UserEnhanceCustomer")

  @@index([email])
  @@index([role_id])
  @@index([status])
  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  token_hash   String   @unique @db.VarChar(500)
  refresh_hash String   @unique @db.VarChar(500)
  ip_address   String   @db.VarChar(45)
  user_agent   String?  @db.VarChar(1000)
  device_label String?  @db.VarChar(200)
  is_active    Boolean  @default(true)
  last_used_at DateTime @default(now()) @db.Timestamptz()
  expires_at   DateTime @db.Timestamptz()
  created_at   DateTime @default(now()) @db.Timestamptz()

  /// Sprint 13 §13.AUTH Fase B (ADR-078 §1.4) — refresh rotation con replay
  /// detection. NULL = refresh todavía válido. Cuando se canjea, se marca con
  /// timestamp y se enlaza a la sesión nueva via `replaced_by_session_id`.
  /// Si llega un refresh con `used_at IS NOT NULL` → REPLAY → revoca la cadena
  /// completa del user (`updateMany`) + emit `auth.refresh_replay_detected`.
  used_at                DateTime? @db.Timestamptz()
  /// FK self con `onDelete: SetNull` — la sesión vieja apunta a la nueva. Si
  /// la nueva se borra (cascade del user), esta queda apuntando a NULL.
  replaced_by_session_id String?   @db.Uuid
  replaced_by            Session?  @relation("SessionReplay", fields: [replaced_by_session_id], references: [id], onDelete: SetNull)
  replaces               Session[] @relation("SessionReplay")
  /// Razón canónica de revocación (cuando `is_active=false`). NULL si la
  /// sesión sigue activa o caducó por TTL sin acción explícita.
  /// Valores: 'logout' | 'replay_detected' | 'manual_revoke' | 'expired' | 'rotated'.
  /// 'rotated' = refresh canjeado en el flow normal (la sesión nueva es la
  /// referenciada por `replaced_by_session_id` y mantiene la cadena viva).
  revoked_reason         String?   @db.VarChar(50)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_active])
  @@index([used_at])
  @@map("sessions")
}

model EmailVerification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(500)
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("email_verifications")
}

model PasswordReset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(500)
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  ip_address String    @db.VarChar(45)
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_resets")
}

// ─── BLOQUE 2: PERFIL DE CLIENTE ───

enum ClientType {
  individual
  company
}

model ClientProfile {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String     @unique @db.Uuid
  client_type        ClientType @default(individual)
  company_name       String?    @db.VarChar(300)
  tax_id             String?    @db.VarChar(20)
  phone              String?    @db.VarChar(20)
  address_line1      String?    @db.VarChar(500)
  address_line2      String?    @db.VarChar(500)
  city               String?    @db.VarChar(100)
  state              String?    @db.VarChar(100)
  postal_code        String?    @db.VarChar(10)
  country            String     @default("ES") @db.VarChar(2)
  billing_email      String?    @db.VarChar(255)
  notes_internal     String?
  stripe_customer_id String?    @db.VarChar(200)
  credit_balance     Decimal    @default(0) @db.Decimal(10, 2)
  metadata           Json?
  created_at         DateTime   @default(now()) @db.Timestamptz()
  updated_at         DateTime   @default(now()) @updatedAt @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

enum BillingProfileType {
  personal
  autonomo
  empresa
}

model BillingProfile {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String             @db.Uuid
  type          BillingProfileType
  label         String             @db.VarChar(100)
  first_name    String?            @db.VarChar(100)
  last_name     String?            @db.VarChar(100)
  company_name  String?            @db.VarChar(200)
  nif_cif       String?            @db.VarChar(20)
  address_line1 String             @db.VarChar(255)
  address_line2 String?            @db.VarChar(255)
  city          String             @db.VarChar(100)
  postal_code   String             @db.VarChar(20)
  country       String             @default("ES") @db.VarChar(2)
  is_default    Boolean            @default(false)
  created_at    DateTime           @default(now()) @db.Timestamptz()
  updated_at    DateTime           @default(now()) @updatedAt @db.Timestamptz()

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  services Service[]
  invoices Invoice[]

  @@index([user_id])
  @@map("billing_profiles")
}

// ─── BLOQUE 3: SETTINGS GLOBALES ───

model Setting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category    String   @db.VarChar(100)
  key         String   @db.VarChar(200)
  value       Json
  description String?
  updated_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@unique([category, key])
  @@index([category])
  @@map("settings")
}

/// Sprint 15A — ADR-080 §2 — Plugin Framework.
///
/// Una fila por plugin de provisioning instalado (`internal`, `manual`,
/// `enhance_cp`, `resellerclub`, `docker_engine`, etc.). Separada de
/// `settings` por diseño: secrets cifrados NUNCA se mezclan con settings
/// generales del cliente.
///
/// PK natural `slug` (NO UUID) — el slug ES la identidad por contrato
/// ADR-077 §1, cardinalidad acotada (~15 plugins de por vida), 3NF
/// aplicado correctamente. Justificación completa en ADR-080 §2.
///
/// `secrets` jsonb almacena blobs cifrados por `SecretVaultService`
/// (AES-256-GCM con `ENCRYPTION_KEY`). Cada campo del shape declarado
/// por `manifest.secretsSchema` se cifra individualmente con su IV propio.
/// `key_version` permite rotación futura (Sprint 15A v1: única clave activa).
model PluginInstall {
  slug         String   @id @db.VarChar(80)
  enabled      Boolean  @default(false)
  config       Json     @default("{}")
  secrets      Json     @default("{}")
  key_version  Int      @default(1)
  installed_at DateTime @default(now()) @db.Timestamptz()
  installed_by String?  @db.Uuid
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz()
  updated_by   String?  @db.Uuid

  @@index([enabled])
  @@map("plugin_installs")
}

/// Sprint 15C Fase 15C.C (2026-05-08) — ADR-083 §2 decisión 7.
///
/// Mapping canónico Client Aelium ↔ Customer Org Enhance.
///
/// PK natural `user_id` (NO UUID extra) — el User Aelium ES la identidad del
/// customer Enhance. Misma doctrina que `plugin_installs.slug` PK natural
/// (ADR-080 §2). Cardinalidad: 1 fila por cada cliente Aelium con al menos
/// un hosting Enhance contratado. Lazy create al primer hosting Enhance
/// (ADR-083 §2 decisión 8) — NO en alta del User.
///
/// `enhance_owner_login_id` + `enhance_owner_member_id` se persisten para
/// optimizar SSO 2-call OTP (ADR-083 §4 decisión 13): permiten omitir el
/// GET /orgs/{cust} previo y llamar directo a /sso → 1 call por SSO.
///
/// Naming: el ADR-083 describe el campo conceptual como `client_id` por
/// semántica (Client Aelium ↔ Customer Org Enhance). El campo SQL real es
/// `user_id` para coherencia con el resto del schema (todos los joins van
/// a `users.id`). La doctrina conceptual es la misma.
model EnhanceCustomer {
  user_id                 String   @id @db.Uuid
  enhance_org_id          String   @unique @db.Uuid
  enhance_owner_login_id  String   @db.Uuid
  enhance_owner_member_id String   @db.Uuid
  created_at              DateTime @default(now()) @db.Timestamptz()
  updated_at              DateTime @default(now()) @updatedAt @db.Timestamptz()

  user User @relation("UserEnhanceCustomer", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("enhance_customers")
}

// ─── BLOQUE 4: PRODUCTOS Y CATÁLOGO ───

enum BillingCycle {
  monthly
  quarterly
  semiannual
  annual
  one_time
}

enum ProductStatus {
  active
  inactive
  deprecated
}

enum ProductType {
  hosting_web // Plans: Web Inicio, Web Pro, Web Business
  domain // Independent product, free first year with annual hosting
  docker_service // Nextcloud, OpenClaw, etc. — template .yaml
  support_inside // Addon global de cuenta (Básico, Medium, Pro) — §7 DECISIONS.md
  we_do_it // Addon por producto (hosting, docker) — §8 DECISIONS.md
  custom_service // Proyectos manuales a escala (ERP, CRM) — §27 DECISIONS.md
}

// ProvisionerType: dinámico via plugin system (Sprint 8).
// Valores conocidos: enhance_cp, resellerclub, docker_engine, internal, manual.
// Se almacena como String para permitir registrar nuevos provisioners sin migraciones.

enum ExtraType {
  free_period
  discount
  included_product
}

enum ExtraApplicableCycle {
  monthly
  annual
  both
}

model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  parent_id   String?  @db.Uuid
  order_index Int      @default(0)
  active      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  parent   ProductCategory?  @relation("category_tree", fields: [parent_id], references: [id])
  children ProductCategory[] @relation("category_tree")
  products Product[]

  @@index([parent_id])
  @@map("product_categories")
}

model Product {
  id                        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id               String?       @db.Uuid
  name                      String        @db.VarChar(200)
  slug                      String        @unique @db.VarChar(200)
  description               String?
  short_description         String?       @db.VarChar(500)
  type                      ProductType
  provisioner               String        @default("manual") @db.VarChar(100)
  image_url                 String?       @db.VarChar(500)
  badge_text                String?       @db.VarChar(50)
  order_index               Int           @default(0)
  status                    ProductStatus @default(active)
  is_addon                  Boolean       @default(false)
  is_global_addon           Boolean       @default(false)
  requires_existing_product Boolean       @default(false)
  required_product_type     String?       @db.VarChar(50)
  max_quantity_per_client   Int?
  grace_period_days         Int           @default(0)
  suspension_days           Int           @default(7)
  cancellation_days         Int           @default(30)
  data_retention_days       Int           @default(30)
  client_can_pause          Boolean       @default(false)
  pause_max_days            Int?
  provisioner_config        Json?
  audit_event_types         Json?
  features                  Json?
  metadata                  Json?
  partner_commission_pct    Decimal?      @db.Decimal(5, 2)
  created_at                DateTime      @default(now()) @db.Timestamptz()
  updated_at                DateTime      @default(now()) @updatedAt @db.Timestamptz()

  category                     ProductCategory?            @relation(fields: [category_id], references: [id])
  pricing                      ProductPricing[]
  extras                       ProductExtra[]
  checklist_items              ProductChecklistItem[]
  services                     Service[]
  support_inside_config        SupportInsideConfig?        @relation("ProductSupportInsideConfig")
  support_inside_subscriptions SupportInsideSubscription[] @relation("ProductSupportInsideSubscriptions")

  @@index([category_id])
  @@index([type])
  @@index([status])
  @@map("products")
}

model ProductPricing {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id          String       @db.Uuid
  billing_cycle       BillingCycle
  price               Decimal      @db.Decimal(10, 2)
  setup_fee           Decimal      @default(0) @db.Decimal(10, 2)
  currency            String       @default("EUR") @db.VarChar(3)
  discount_percentage Decimal?     @db.Decimal(5, 2)
  active              Boolean      @default(true)
  created_at          DateTime     @default(now()) @db.Timestamptz()
  updated_at          DateTime     @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, billing_cycle, currency])
  @@map("product_pricing")
}

model ProductExtra {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id          String               @db.Uuid
  extra_product_id    String?              @db.Uuid
  type                ExtraType
  is_mandatory        Boolean              @default(false)
  label               String               @db.VarChar(200)
  discount_percentage Decimal?             @db.Decimal(5, 2)
  free_months         Int?
  max_value_eur       Decimal?             @db.Decimal(10, 2)
  applicable_cycles   ExtraApplicableCycle @default(annual)
  tld_restrictions    Json?
  valid_until         DateTime?            @db.Timestamptz()
  max_uses            Int?
  uses_count          Int                  @default(0)
  active              Boolean              @default(true)
  created_at          DateTime             @default(now()) @db.Timestamptz()
  updated_at          DateTime             @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_extras")
}

model ProductChecklistItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String   @db.Uuid
  label       String   @db.VarChar(200)
  order_index Int      @default(0)
  is_required Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_checklist_items")
}

// ─── BLOQUE 5: SERVICIOS ───

enum ServiceStatus {
  pending
  provisioning
  active
  suspended
  cancelled
  terminated
}

// Sprint 15C.II Fase F.8 (ADR §A.11.10.5.1 frozen 2026-05-16) — Alertas de cuota.
//
// `QuotaAlertResource` y `QuotaAlertKind` modelan el state-tracking
// edge-triggered del detector `QuotaThresholdDetectorService`
// (core/provisioning/). F.8 entrega solo `disk` (cuota dura); `bandwidth`
// queda fuera porque su reset mensual rompe el edge-trigger sin handler
// especial — promoción futura F.8.x. Patrón Prometheus/AlertManager.
enum QuotaAlertResource {
  disk
}

enum QuotaAlertKind {
  crossed_up
  crossed_down
}

model Service {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String        @db.Uuid
  product_id          String        @db.Uuid
  billing_profile_id  String?       @db.Uuid
  partner_id          String?       @db.Uuid
  status              ServiceStatus @default(pending)
  label               String?       @db.VarChar(300)
  domain              String?       @db.VarChar(300)
  server_id           String?       @db.Uuid
  billing_cycle       BillingCycle  @default(monthly)
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("EUR") @db.VarChar(3)
  next_due_date       DateTime?     @db.Timestamptz()
  next_invoice_date   DateTime?     @db.Timestamptz()
  cancelled_at        DateTime?     @db.Timestamptz()
  cancellation_reason String?
  suspended_at        DateTime?     @db.Timestamptz()
  suspension_reason   String?
  paused_at           DateTime?     @db.Timestamptz()
  pause_max_date      DateTime?     @db.Timestamptz()
  // Sprint 11 Fase 11.B (ADR-077): denormalizado de `product.provisioner` al
  // provisionar. Inmutable tras `service.activated` — el plugin que provisionó
  // es el dueño del lifecycle aunque el admin cambie luego `product.provisioner`.
  provisioner_slug    String?       @db.VarChar(100)
  // Sprint 11 Fase 11.B (ADR-077 §2.2): ID del recurso en el sistema externo.
  // NULL para plugins `internal`/`manual`. Indexado para reconciliación cron.
  provider_reference  String?       @db.VarChar(500)
  provisioner_data    Json?
  metadata            Json?
  created_at          DateTime      @default(now()) @db.Timestamptz()
  updated_at          DateTime      @default(now()) @updatedAt @db.Timestamptz()

  product                     Product                    @relation(fields: [product_id], references: [id])
  billing_profile             BillingProfile?            @relation(fields: [billing_profile_id], references: [id])
  // Sprint 16 (ADR-079): la relación directa Service ↔ Task (vía `service_id` FK)
  // se eliminó. Las tasks de tipo `provisioning_manual` ahora apuntan al
  // service vía `Task.source_id` polimórfico (sin FK Prisma) — la integridad
  // referencial se gestiona en listeners (`tasks-on-service-cancelled`).
  maintenance_logs            MaintenanceLog[]           @relation("ServiceMaintenanceLogs")
  checklist_items             ServiceChecklistItem[]     @relation("ServiceChecklistItems")
  support_inside_subscription SupportInsideSubscription? @relation("ServiceSupportInsideSubscription")
  support_inside_slots        SupportInsideSlot[]        @relation("ServiceSupportInsideSlots")
  // Sprint 15C.II Fase F.8 — historial edge-triggered de alertas de cuota.
  // Solo se popula para plugins con `has_metrics`; el detector inserta
  // `crossed_up`/`crossed_down` en `$transaction` serializable. FK
  // `ON DELETE Cascade` — si el service se elimina físicamente, su historial
  // de alertas no tiene sentido aislado.
  quota_alerts                ServiceQuotaAlert[]        @relation("ServiceQuotaAlerts")

  @@index([user_id])
  @@index([product_id])
  @@index([billing_profile_id])
  @@index([status])
  @@index([next_due_date])
  // Sprint 11 Fase 11.B: provisioner_slug indexado para queries de
  // reconciliación cron y filtro admin (`/admin/services?provisioner=...`).
  @@index([provisioner_slug])
  // Sprint 11 Fase 11.B: provider_reference indexado para resolver el servicio
  // desde callbacks/webhooks del proveedor (`WHERE provider_reference = X`).
  @@index([provider_reference])
  @@map("services")
}

// Sprint 15C.II Fase F.8 (frozen 2026-05-16 — dossier §A.11.10.5.1 R1).
//
// State-tracking edge-triggered de alertas de cuota por (service, resource).
// El detector (`QuotaThresholdDetectorService` en core/provisioning/) inserta:
//   - `crossed_up`   cuando `pct >= threshold` Y la última fila previa era
//                    `crossed_down` (o no había fila) → dispara email vía
//                    evento `service.quota_threshold_crossed`.
//   - `crossed_down` cuando `pct <  threshold` Y la última fila previa era
//                    `crossed_up` → solo state-tracking, sin emit.
//
// La inserción ocurre en `$transaction` serializable junto a la lectura del
// estado previo (M2 — idempotency operativa). El emit del evento queda
// fuera de la tx (R7 — degradación elegante: si el dispatch falla, la fila
// ya capturó el estado y la siguiente pasada NO re-emite).
//
// Diseño heredable a todo plugin con `has_metrics` (15E Docker / 15G Plesk).
// 15D RC no aplica (sin métricas).
model ServiceQuotaAlert {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id    String             @db.Uuid
  resource      QuotaAlertResource
  kind          QuotaAlertKind
  used_pct      Decimal            @db.Decimal(5, 2)
  threshold_pct Decimal            @db.Decimal(5, 2)
  detected_at   DateTime           @default(now()) @db.Timestamptz()

  service Service @relation("ServiceQuotaAlerts", fields: [service_id], references: [id], onDelete: Cascade)

  // Lookup canónico: `findFirst({ where: {service_id, resource}, orderBy: {detected_at:'desc'} })`.
  @@index([service_id, resource, detected_at])
  @@map("service_quota_alerts")
}

// ─── BLOQUE 6: FACTURACIÓN ───

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
  refunded
}

model Invoice {
