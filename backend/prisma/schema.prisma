  processing
  done
  failed
}

model EventOutbox {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type    String      @db.VarChar(200)
  payload       Json
  status        EventStatus @default(pending)
  retry_count   Int         @default(0)
  max_retries   Int         @default(5)
  last_error    String?
  processed_at  DateTime?   @db.Timestamptz()
  next_retry_at DateTime?   @db.Timestamptz()
  created_at    DateTime    @default(now()) @db.Timestamptz()

  @@index([status, next_retry_at])
  @@index([created_at])
  @@map("event_outbox")
}

// ─── BLOQUE 12: ERROR LOG ───

model ErrorLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level          String   @default("error") @db.VarChar(20)
  module         String   @db.VarChar(100)
  message        String
  stack_trace    String?
  correlation_id String?  @db.VarChar(100)
  user_id        String?  @db.Uuid
  request_path   String?  @db.VarChar(1000)
  request_method String?  @db.VarChar(10)
  metadata       Json?
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([module])
  @@index([level])
  @@index([correlation_id])
  @@index([created_at])
  @@map("error_log")
}

// ─── AUDIT SCHEMA (solo INSERT) ───

model AuditAccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  action     String   @db.VarChar(100)
  ip_address String   @db.VarChar(45)
  user_agent String?  @db.VarChar(1000)
  resource   String?  @db.VarChar(200)
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_access_log")
}

model AuditChangeLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?  @db.Uuid
  entity_type    String   @db.VarChar(100)
  entity_id      String   @db.Uuid
  action         String   @db.VarChar(50)
  changes_before Json?
  changes_after  Json?
  correlation_id String?  @db.VarChar(100)
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([entity_type, entity_id])
  @@index([user_id])
  @@index([created_at])
  @@map("audit_change_log")
}

// ─── BLOQUE 13: DLQ — JOBS FALLIDOS (Sprint 9 Fase A — ADR-063) ───

enum FailedJobStatus {
  failed
  retrying
  resolved
}

model FailedJob {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bull_job_id   String          @db.VarChar(200)
  queue         String          @db.VarChar(100)
  name          String          @db.VarChar(200)
  payload       Json
  last_error    String
  stack_trace   String?
  attempts_made Int
  retried_at    DateTime?       @db.Timestamptz()
  retried_by    String?         @db.Uuid
  status        FailedJobStatus @default(failed)
  created_at    DateTime        @default(now()) @db.Timestamptz()

  @@index([queue, status])
  @@index([created_at])
  @@map("failed_jobs")
}
