  ticket
}

enum ConversationCategory {
  support_general
  support_billing
  support_technical
  wdify_progress
  wdify_feedback
  escalated_chat
}

model Conversation {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sequence_number    Int?                  @unique // Auto-assigned via PostgreSQL SEQUENCE on ticket creation
  type               ConversationType      @default(chat)
  user_id            String?               @db.Uuid
  assigned_agent_id  String?               @db.Uuid
  subject            String                @db.VarChar(500)
  status             ConversationStatus    @default(open)
  priority           ConversationPriority  @default(normal)
  category           ConversationCategory?
  channel            String                @default("web") @db.VarChar(50)
  is_ai_filtered     Boolean               @default(false)
  guest_name         String?               @db.VarChar(200) // Para anónimos en la landing
  guest_email        String?               @db.VarChar(255) // Para vincular al registrarse (7.5.1)
  guest_session_hash String?               @db.VarChar(500) // Hash SHA-256 del token de sesión guest
  service_id         String?               @db.Uuid
  escalated_from_id  String?               @db.Uuid
  tags               Json?
  closed_at          DateTime?             @db.Timestamptz()
